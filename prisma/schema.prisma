// ============================================================================
//  ComerziaHub — Prisma schema (PostgreSQL)
//  Plataforma de estoque, delivery, marketplace e rede social comercial.
//
//  Organização por domínios:
//   1. Auth & usuários / permissões
//   2. Lojas, funcionários e configurações
//   3. Catálogo, variações e estoque
//   4. Carrinho, pedidos, pagamentos
//   5. Delivery & entregadores
//   6. Endereços & avaliações
//   7. Cashback, fidelidade, emblemas & cupons
//   8. Rede social (posts, comentários, follows, mensagens, denúncias)
//   9. Notificações, planos, assinaturas & configurações da plataforma
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Para provedores serverless (Neon/Vercel) descomente e configure DIRECT_URL:
  // directUrl = env("DIRECT_URL")
}

// ======================== ENUMS ============================================

enum UserRole {
  ADMIN // administrador geral da plataforma
  STORE_OWNER // dono de loja
  STORE_EMPLOYEE // funcionário da loja
  SELLER // vendedor
  CUSTOMER // cliente/comprador
  COURIER // entregador
  MODERATOR // moderador da rede social
}

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
  BANNED
}

enum StoreStatus {
  PENDING // aguardando aprovação do admin
  ACTIVE
  PAUSED
  SUSPENDED
}

enum StoreMemberRole {
  OWNER
  MANAGER
  STAFF
  SELLER
}

enum ProductStatus {
  ACTIVE
  PAUSED
  OUT_OF_STOCK
  DRAFT
}

enum StockMovementType {
  IN // entrada
  OUT // saída manual
  ADJUSTMENT // ajuste de inventário
  SALE // baixa por venda
  RETURN // devolução
}

enum OrderStatus {
  PENDING // aguardando a loja aceitar
  ACCEPTED // loja aceitou
  REJECTED // loja recusou
  PREPARING // em separação/preparo
  READY // pronto p/ retirada ou coleta
  OUT_FOR_DELIVERY // saiu para entrega
  DELIVERED // entregue
  COMPLETED // concluído (pós avaliação)
  CANCELLED // cancelado
}

enum FulfillmentType {
  DELIVERY
  PICKUP
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  DEBIT_CARD
  CASH_ON_DELIVERY
  WALLET // carteira interna
  CASHBACK // cashback como pagamento
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum CourierStatus {
  PENDING // documentos em análise
  APPROVED
  REJECTED
  SUSPENDED
}

enum VehicleType {
  BIKE
  MOTORCYCLE
  CAR
  FOOT
}

enum DeliveryStatus {
  PENDING // disponível para aceite
  ASSIGNED // atribuída a um entregador
  ACCEPTED // entregador aceitou
  PICKED_UP // coletado na loja
  IN_TRANSIT // a caminho
  DELIVERED
  CANCELLED
  FAILED
}

enum ReviewType {
  STORE
  PRODUCT
  COURIER
}

enum CashbackType {
  PERCENT
  FIXED
}

enum CashbackTxType {
  EARNED
  REDEEMED
  EXPIRED
  REVERSED
}

enum CashbackStatus {
  PENDING // dentro do prazo de liberação
  AVAILABLE // liberado para uso
  USED
  EXPIRED
  CANCELLED
}

enum DiscountType {
  PERCENT
  FIXED
  FREE_SHIPPING
}

enum PostType {
  TEXT
  IMAGE
  PROMOTION
  PRODUCT
  NEWS
}

enum PostStatus {
  PUBLISHED
  HIDDEN
  REMOVED
}

enum FriendStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum NotificationType {
  ORDER
  DELIVERY
  SOCIAL
  CASHBACK
  LOYALTY
  MESSAGE
  PROMOTION
  SYSTEM
}

enum ReportTargetType {
  POST
  COMMENT
  USER
  STORE
  PRODUCT
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

enum PlanInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum WalletTxType {
  CREDIT
  DEBIT
}

// ======================== 1. AUTH & USUÁRIOS ===============================

model User {
  id            String     @id @default(cuid())
  name          String
  email         String     @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  phone         String?
  document      String? // CPF/CNPJ
  bio           String?
  role          UserRole   @default(CUSTOMER)
  status        UserStatus @default(ACTIVE)
  isPrivate     Boolean    @default(false) // configurações de privacidade
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Auth.js
  accounts            Account[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]

  // RBAC
  permissions UserPermission[]

  // Comércio
  addresses          Address[]
  ownedStores        Store[]              @relation("StoreOwner")
  memberships        StoreMember[]
  orders             Order[]              @relation("CustomerOrders")
  cart               Cart?
  productFavorites   ProductFavorite[]
  storeFavorites     StoreFavorite[]
  couponRedemptions  CouponRedemption[]
  reviewsAuthored    Review[]             @relation("ReviewAuthor")
  stockMovements     StockMovement[]      @relation("StockMovementBy")
  orderStatusUpdates OrderStatusHistory[] @relation("OrderStatusBy")

  // Delivery
  courierProfile CourierProfile?

  // Cashback / fidelidade / carteira
  cashbackTransactions CashbackTransaction[]
  cashbackWallets      CashbackWallet[]
  loyaltyStatuses      LoyaltyStatus[]
  badges               UserBadge[]
  wallet               Wallet?

  // Rede social
  posts           Post[]                    @relation("PostAuthor")
  comments        Comment[]                 @relation("CommentAuthor")
  postLikes       PostLike[]
  commentLikes    CommentLike[]
  shares          Share[]
  following       Follow[]                  @relation("Follower")
  followers       Follow[]                  @relation("Following")
  storeFollows    StoreFollow[]
  friendshipsSent Friendship[]              @relation("FriendRequester")
  friendshipsRecv Friendship[]              @relation("FriendAddressee")
  blocksMade      Block[]                   @relation("Blocker")
  blocksReceived  Block[]                   @relation("Blocked")
  conversations   ConversationParticipant[]
  messagesSent    Message[]                 @relation("MessageSender")
  notifications   Notification[]
  reportsMade     Report[]                  @relation("Reporter")
  reportsResolved Report[]                  @relation("ReportResolver")

  @@index([role])
  @@index([status])
}

// --- Auth.js adapter models (OAuth/sessões futuras) ---
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expires   DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// --- Permissões (RBAC granular além do papel) ---
model Permission {
  id          String           @id @default(cuid())
  key         String           @unique // ex.: "store.products.write"
  description String?
  users       UserPermission[]
}

model UserPermission {
  userId       String
  permissionId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
}

// ======================== 2. LOJAS =========================================

model Store {
  id            String      @id @default(cuid())
  slug          String      @unique
  name          String
  description   String?
  segment       String? // ex.: "Restaurante", "Mercado", "Moda"
  logoUrl       String?
  bannerUrl     String?
  email         String?
  phone         String?
  document      String? // CNPJ
  status        StoreStatus @default(PENDING)
  isOpen        Boolean     @default(true)
  ratingAvg     Float       @default(0)
  ratingCount   Int         @default(0)
  followerCount Int         @default(0)
  // Localização da loja (origem do delivery)
  lat           Float?
  lng           Float?
  ownerId       String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  owner         User           @relation("StoreOwner", fields: [ownerId], references: [id])
  members       StoreMember[]
  settings      StoreSettings?
  businessHours BusinessHour[]
  deliveryZones DeliveryZone[]
  address       Address?       @relation("StoreAddress")

  categories           Category[]
  products             Product[]
  orders               Order[]
  coupons              Coupon[]
  cashbackRules        CashbackRule[]
  cashbackTransactions CashbackTransaction[]
  cashbackWallets      CashbackWallet[]
  loyaltyTiers         LoyaltyTier[]
  loyaltyStatuses      LoyaltyStatus[]
  badges               Badge[]
  reviews              Review[]
  stockMovements       StockMovement[]
  posts                Post[]
  followers            StoreFollow[]
  favorites            StoreFavorite[]
  subscription         Subscription?

  @@index([status])
  @@index([ownerId])
}

model StoreMember {
  id        String          @id @default(cuid())
  storeId   String
  userId    String
  role      StoreMemberRole @default(STAFF)
  title     String?
  active    Boolean         @default(true)
  createdAt DateTime        @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storeId, userId])
  @@index([userId])
}

model StoreSettings {
  id                    String   @id @default(cuid())
  storeId               String   @unique
  currency              String   @default("BRL")
  minOrderValue         Decimal  @default(0) @db.Decimal(12, 2)
  prepTimeMinutes       Int      @default(30)
  acceptsDelivery       Boolean  @default(true)
  acceptsPickup         Boolean  @default(true)
  autoAcceptOrders      Boolean  @default(false)
  deliveryFeeBase       Decimal  @default(0) @db.Decimal(12, 2)
  deliveryFeePerKm      Decimal  @default(0) @db.Decimal(12, 2)
  freeDeliveryThreshold Decimal? @db.Decimal(12, 2)
  maxDeliveryRadiusKm   Float    @default(10)
  cashbackEnabled       Boolean  @default(false)
  loyaltyEnabled        Boolean  @default(false)

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model BusinessHour {
  id       String  @id @default(cuid())
  storeId  String
  weekday  Int // 0=domingo ... 6=sábado
  opensAt  String // "HH:mm"
  closesAt String
  isClosed Boolean @default(false)

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, weekday])
}

model DeliveryZone {
  id               String  @id @default(cuid())
  storeId          String
  name             String
  maxDistanceKm    Float
  fee              Decimal @db.Decimal(12, 2)
  minOrderValue    Decimal @default(0) @db.Decimal(12, 2)
  estimatedMinutes Int     @default(45)

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

// ======================== 3. CATÁLOGO & ESTOQUE ============================

model Category {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  icon     String?
  parentId String?
  storeId  String? // null = categoria global da plataforma

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  store    Store?     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([parentId])
  @@index([storeId])
}

model Product {
  id            String        @id @default(cuid())
  storeId       String
  categoryId    String?
  name          String
  slug          String
  description   String?
  brand         String?
  sku           String?
  status        ProductStatus @default(ACTIVE)
  basePrice     Decimal       @db.Decimal(12, 2)
  promoPrice    Decimal?      @db.Decimal(12, 2)
  promoStartsAt DateTime?
  promoEndsAt   DateTime?
  manageStock   Boolean       @default(true)
  stock         Int           @default(0) // usado quando não há variações
  isFeatured    Boolean       @default(false)
  allowCashback Boolean       @default(true)
  ratingAvg     Float         @default(0)
  ratingCount   Int           @default(0)
  salesCount    Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  store          Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category       Category?         @relation(fields: [categoryId], references: [id])
  images         ProductImage[]
  variants       ProductVariant[]
  stockMovements StockMovement[]
  orderItems     OrderItem[]
  cartItems      CartItem[]
  reviews        Review[]
  favorites      ProductFavorite[]
  posts          Post[]

  @@unique([storeId, slug])
  @@index([storeId])
  @@index([categoryId])
  @@index([status])
  @@index([isFeatured])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  position  Int     @default(0)
  isPrimary Boolean @default(false)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductVariant {
  id            String        @id @default(cuid())
  productId     String
  name          String // ex.: "Tamanho M / Azul"
  sku           String?
  // Atributos flexíveis: { "tamanho": "M", "cor": "Azul", "sabor": "...", "modelo": "..." }
  attributes    Json?
  price         Decimal?      @db.Decimal(12, 2) // preço absoluto opcional
  priceModifier Decimal       @default(0) @db.Decimal(12, 2) // ou ajuste sobre o preço base
  stock         Int           @default(0)
  status        ProductStatus @default(ACTIVE)
  position      Int           @default(0)

  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems     OrderItem[]
  cartItems      CartItem[]
  stockMovements StockMovement[]

  @@index([productId])
}

model StockMovement {
  id          String            @id @default(cuid())
  storeId     String
  productId   String
  variantId   String?
  type        StockMovementType
  quantity    Int
  reason      String?
  reference   String? // ex.: orderId
  createdById String?
  createdAt   DateTime          @default(now())

  store     Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  createdBy User?           @relation("StockMovementBy", fields: [createdById], references: [id])

  @@index([storeId])
  @@index([productId])
}

// ======================== 4. CARRINHO, PEDIDOS, PAGAMENTOS =================

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  variantId String?
  quantity  Int      @default(1)
  unitPrice Decimal  @db.Decimal(12, 2) // snapshot
  createdAt DateTime @default(now())

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([cartId, productId, variantId])
  @@index([cartId])
}

model Order {
  id              String          @id @default(cuid())
  code            String          @unique // ex.: CMZ-AB12CD
  customerId      String
  storeId         String
  status          OrderStatus     @default(PENDING)
  fulfillmentType FulfillmentType @default(DELIVERY)

  subtotal       Decimal @db.Decimal(12, 2)
  discountTotal  Decimal @default(0) @db.Decimal(12, 2)
  cashbackUsed   Decimal @default(0) @db.Decimal(12, 2)
  deliveryFee    Decimal @default(0) @db.Decimal(12, 2)
  total          Decimal @db.Decimal(12, 2)
  cashbackEarned Decimal @default(0) @db.Decimal(12, 2)

  couponId  String?
  addressId String?
  notes     String?

  placedAt    DateTime  @default(now())
  acceptedAt  DateTime?
  readyAt     DateTime?
  deliveredAt DateTime?
  cancelledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  customer             User                  @relation("CustomerOrders", fields: [customerId], references: [id])
  store                Store                 @relation(fields: [storeId], references: [id])
  coupon               Coupon?               @relation(fields: [couponId], references: [id])
  address              Address?              @relation(fields: [addressId], references: [id])
  items                OrderItem[]
  payment              Payment?
  delivery             Delivery?
  statusHistory        OrderStatusHistory[]
  cashbackTransactions CashbackTransaction[]
  couponRedemptions    CouponRedemption[]
  reviews              Review[]

  @@index([customerId])
  @@index([storeId])
  @@index([status])
}

model OrderItem {
  id              String  @id @default(cuid())
  orderId         String
  productId       String?
  variantId       String?
  name            String // snapshot do nome
  unitPrice       Decimal @db.Decimal(12, 2)
  quantity        Int
  total           Decimal @db.Decimal(12, 2)
  cashbackPercent Decimal @default(0) @db.Decimal(5, 2)

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?        @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
}

model OrderStatusHistory {
  id          String      @id @default(cuid())
  orderId     String
  status      OrderStatus
  note        String?
  createdById String?
  createdAt   DateTime    @default(now())

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdBy User? @relation("OrderStatusBy", fields: [createdById], references: [id])

  @@index([orderId])
}

model Payment {
  id          String        @id @default(cuid())
  orderId     String        @unique
  method      PaymentMethod
  status      PaymentStatus @default(PENDING)
  amount      Decimal       @db.Decimal(12, 2)
  provider    String? // gateway futuro
  providerRef String? // id da transação no PSP
  paidAt      DateTime?
  createdAt   DateTime      @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ======================== 5. DELIVERY & ENTREGADORES =======================

model CourierProfile {
  id                String        @id @default(cuid())
  userId            String        @unique
  status            CourierStatus @default(PENDING)
  isOnline          Boolean       @default(false)
  vehicleType       VehicleType   @default(MOTORCYCLE)
  pixKey            String?
  bankInfo          Json?
  documentsApproved Boolean       @default(false)
  currentLat        Float?
  currentLng        Float?
  ratingAvg         Float         @default(0)
  ratingCount       Int           @default(0)
  deliveriesCount   Int           @default(0)
  createdAt         DateTime      @default(now())

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents  CourierDocument[]
  deliveries Delivery[]
}

model CourierDocument {
  id        String   @id @default(cuid())
  courierId String
  type      String // CNH, RG, CRLV, COMPROVANTE_ENDERECO...
  url       String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  courier CourierProfile @relation(fields: [courierId], references: [id], onDelete: Cascade)

  @@index([courierId])
}

model Delivery {
  id               String         @id @default(cuid())
  orderId          String         @unique
  courierId        String?
  status           DeliveryStatus @default(PENDING)
  distanceKm       Float          @default(0)
  fee              Decimal        @default(0) @db.Decimal(12, 2)
  courierEarnings  Decimal        @default(0) @db.Decimal(12, 2)
  platformFee      Decimal        @default(0) @db.Decimal(12, 2)
  estimatedMinutes Int            @default(45)
  pickupLat        Float?
  pickupLng        Float?
  dropoffLat       Float?
  dropoffLng       Float?
  currentLat       Float?
  currentLng       Float?
  acceptedAt       DateTime?
  pickedUpAt       DateTime?
  deliveredAt      DateTime?
  createdAt        DateTime       @default(now())

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  courier CourierProfile? @relation(fields: [courierId], references: [id])

  @@index([courierId])
  @@index([status])
}

// ======================== 6. ENDEREÇOS & AVALIAÇÕES ========================

model Address {
  id            String   @id @default(cuid())
  userId        String?
  storeId       String?  @unique // endereço/origem da loja
  label         String? // "Casa", "Trabalho"
  recipientName String?
  phone         String?
  zip           String?
  street        String?
  number        String?
  complement    String?
  district      String?
  city          String?
  state         String?
  country       String   @default("BR")
  lat           Float?
  lng           Float?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  store  Store?  @relation("StoreAddress", fields: [storeId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
}

model Review {
  id        String     @id @default(cuid())
  authorId  String
  type      ReviewType
  rating    Int // 1..5
  comment   String?
  storeId   String?
  productId String?
  courierId String?
  orderId   String?
  createdAt DateTime   @default(now())

  author  User     @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  store   Store?   @relation(fields: [storeId], references: [id])
  product Product? @relation(fields: [productId], references: [id])
  order   Order?   @relation(fields: [orderId], references: [id])

  @@index([storeId])
  @@index([productId])
  @@index([courierId])
}

// ======================== 7. CASHBACK, FIDELIDADE & CUPONS =================

model CashbackRule {
  id                   String       @id @default(cuid())
  storeId              String
  name                 String
  type                 CashbackType @default(PERCENT)
  value                Decimal      @db.Decimal(12, 2) // % ou valor fixo
  maxValue             Decimal?     @db.Decimal(12, 2)
  minOrderValue        Decimal      @default(0) @db.Decimal(12, 2)
  releaseAfterDays     Int          @default(0) // prazo de liberação
  validityDays         Int          @default(90) // validade do cashback
  excludePromoProducts Boolean      @default(false)
  active               Boolean      @default(true)
  startsAt             DateTime?
  endsAt               DateTime?
  createdAt            DateTime     @default(now())

  store        Store                 @relation(fields: [storeId], references: [id], onDelete: Cascade)
  transactions CashbackTransaction[]

  @@index([storeId])
}

model CashbackTransaction {
  id          String         @id @default(cuid())
  userId      String
  storeId     String
  orderId     String?
  ruleId      String?
  type        CashbackTxType
  status      CashbackStatus @default(PENDING)
  amount      Decimal        @db.Decimal(12, 2)
  availableAt DateTime? // quando fica disponível
  expiresAt   DateTime?
  createdAt   DateTime       @default(now())

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order Order?        @relation(fields: [orderId], references: [id])
  rule  CashbackRule? @relation(fields: [ruleId], references: [id])

  @@index([userId])
  @@index([storeId])
}

model CashbackWallet {
  id      String  @id @default(cuid())
  userId  String
  storeId String
  balance Decimal @default(0) @db.Decimal(12, 2)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
}

// Carteira interna da plataforma (saldo geral do usuário)
model Wallet {
  id           String              @id @default(cuid())
  userId       String              @unique
  balance      Decimal             @default(0) @db.Decimal(12, 2)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
}

model WalletTransaction {
  id          String       @id @default(cuid())
  walletId    String
  type        WalletTxType
  amount      Decimal      @db.Decimal(12, 2)
  description String?
  reference   String?
  createdAt   DateTime     @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
}

model LoyaltyTier {
  id        String  @id @default(cuid())
  storeId   String
  name      String // Bronze, Prata, Ouro, Diamante, VIP
  level     Int // ordem (1,2,3...)
  minOrders Int     @default(0)
  minSpend  Decimal @default(0) @db.Decimal(12, 2)
  color     String? // cor do selo
  // Benefícios: { discountPercent, cashbackBoost, freeShipping, couponCode, exclusiveProducts }
  benefits  Json?

  store    Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  statuses LoyaltyStatus[]

  @@unique([storeId, level])
  @@index([storeId])
}

model LoyaltyStatus {
  id          String   @id @default(cuid())
  userId      String
  storeId     String
  tierId      String?
  totalOrders Int      @default(0)
  totalSpend  Decimal  @default(0) @db.Decimal(12, 2)
  points      Int      @default(0)
  updatedAt   DateTime @updatedAt

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  tier  LoyaltyTier? @relation(fields: [tierId], references: [id])

  @@unique([userId, storeId])
  @@index([storeId])
}

model Badge {
  id          String  @id @default(cuid())
  storeId     String? // null = emblema global
  name        String
  description String?
  iconUrl     String?
  criteria    Json?

  store      Store?      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  userBadges UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

model Coupon {
  id                    String       @id @default(cuid())
  storeId               String? // null = cupom da plataforma
  code                  String
  description           String?
  type                  DiscountType @default(PERCENT)
  value                 Decimal      @db.Decimal(12, 2)
  minOrderValue         Decimal      @default(0) @db.Decimal(12, 2)
  maxDiscount           Decimal?     @db.Decimal(12, 2)
  usageLimit            Int?
  usageCount            Int          @default(0)
  perUserLimit          Int?
  requiresLoyaltyTierId String?
  active                Boolean      @default(true)
  startsAt              DateTime?
  endsAt                DateTime?
  createdAt             DateTime     @default(now())

  store       Store?             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders      Order[]
  redemptions CouponRedemption[]

  @@unique([storeId, code])
  @@index([storeId])
}

model CouponRedemption {
  id        String   @id @default(cuid())
  couponId  String
  userId    String
  orderId   String?
  createdAt DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order  Order? @relation(fields: [orderId], references: [id])

  @@index([couponId])
  @@index([userId])
}

model ProductFavorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model StoreFavorite {
  id        String   @id @default(cuid())
  userId    String
  storeId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
  @@index([userId])
}

// ======================== 8. REDE SOCIAL ===================================

model Post {
  id           String     @id @default(cuid())
  authorId     String
  storeId      String? // post publicado pela loja
  type         PostType   @default(TEXT)
  content      String?
  productId    String? // publicação de produto
  status       PostStatus @default(PUBLISHED)
  likeCount    Int        @default(0)
  commentCount Int        @default(0)
  shareCount   Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  author   User        @relation("PostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  store    Store?      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product  Product?    @relation(fields: [productId], references: [id])
  images   PostImage[]
  comments Comment[]
  likes    PostLike[]
  shares   Share[]

  @@index([authorId])
  @@index([storeId])
  @@index([status])
}

model PostImage {
  id       String @id @default(cuid())
  postId   String
  url      String
  position Int    @default(0)

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  parentId  String?
  content   String
  likeCount Int      @default(0)
  createdAt DateTime @default(now())

  post    Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User          @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  parent  Comment?      @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[]     @relation("CommentReplies")
  likes   CommentLike[]

  @@index([postId])
  @@index([authorId])
}

model PostLike {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model CommentLike {
  id        String   @id @default(cuid())
  userId    String
  commentId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
}

model Share {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model StoreFollow {
  id        String   @id @default(cuid())
  userId    String
  storeId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
}

model Friendship {
  id          String       @id @default(cuid())
  requesterId String
  addresseeId String
  status      FriendStatus @default(PENDING)
  createdAt   DateTime     @default(now())

  requester User @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
}

model Conversation {
  id           String                    @id @default(cuid())
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Report {
  id           String           @id @default(cuid())
  reporterId   String
  targetType   ReportTargetType
  targetId     String
  reason       String
  description  String?
  status       ReportStatus     @default(PENDING)
  resolvedById String?
  createdAt    DateTime         @default(now())

  reporter   User  @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  resolvedBy User? @relation("ReportResolver", fields: [resolvedById], references: [id])

  @@index([status])
  @@index([targetType])
}

// ======================== 9. NOTIFICAÇÕES, PLANOS & CONFIG =================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Plan {
  id             String       @id @default(cuid())
  name           String       @unique // FREE, PRO, BUSINESS
  description    String?
  price          Decimal      @default(0) @db.Decimal(12, 2)
  interval       PlanInterval @default(MONTHLY)
  commissionRate Decimal      @default(0) @db.Decimal(5, 2) // taxa da plataforma (%)
  maxProducts    Int?
  features       Json?
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())

  subscriptions Subscription[]
}

model Subscription {
  id               String             @id @default(cuid())
  storeId          String             @unique
  planId           String
  status           SubscriptionStatus @default(TRIALING)
  startedAt        DateTime           @default(now())
  currentPeriodEnd DateTime?
  createdAt        DateTime           @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  plan  Plan  @relation(fields: [planId], references: [id])
}

model PlatformSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  updatedAt   DateTime @updatedAt
}
