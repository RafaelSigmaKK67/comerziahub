# ==========================================================================
# ComerziaHub — variáveis de ambiente
# Copie este arquivo para `.env` e preencha os valores.
# ==========================================================================

# --- Banco de dados (PostgreSQL) ------------------------------------------
# Local (Docker/postgres): postgresql://postgres:postgres@localhost:5432/comerziahub?schema=public
# Vercel Postgres / Neon / Supabase: use a connection string fornecida (com sslmode=require)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/comerziahub?schema=public"
# Para provedores serverless (Neon/Vercel) que oferecem URL direta para migrations:
# DIRECT_URL="postgresql://..."

# --- Autenticação (Auth.js / NextAuth v5) ---------------------------------
# Gere um segredo com: npx auth secret   (ou)  openssl rand -base64 32
AUTH_SECRET="troque-este-valor-por-um-segredo-aleatorio-de-32-bytes"
# URL pública da aplicação (em produção use a URL da Vercel)
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# --- App ------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="ComerziaHub"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Mapas / Localização (integração futura) ------------------------------
# Chave para Google Maps / Mapbox quando o módulo de mapa for ativado.
NEXT_PUBLIC_MAPS_PROVIDER="none"
NEXT_PUBLIC_MAPS_API_KEY=""

# --- Upload de imagens (integração futura) --------------------------------
# Configure um provider (Vercel Blob, S3, Cloudinary, UploadThing...).
UPLOAD_PROVIDER="local"
# BLOB_READ_WRITE_TOKEN=""

# --- Pagamentos (integração futura) ---------------------------------------
# Stripe / Mercado Pago / Pix PSP — apenas placeholders por enquanto.
PAYMENT_PROVIDER="mock"
# PAYMENT_API_KEY=""
