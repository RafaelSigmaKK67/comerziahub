# ==========================================================================
# ComerziaHub — variáveis de ambiente
# Copie este arquivo para `.env` e preencha os valores.
# ==========================================================================

# --- Banco de dados (MySQL / MariaDB) -------------------------------------
# XAMPP (phpMyAdmin) local — usuário root sem senha (padrão do XAMPP):
DATABASE_URL="mysql://root@localhost:3306/estoque_delivery"
# Se o root tiver senha:  mysql://root:SUASENHA@localhost:3306/estoque_delivery
# Produção (PlanetScale/Railway/Aiven etc.): use a connection string fornecida.

# --- Autenticação (Auth.js / NextAuth v5) ---------------------------------
# Gere um segredo com: npx auth secret   (ou)  openssl rand -base64 32
AUTH_SECRET="troque-este-valor-por-um-segredo-aleatorio-de-32-bytes"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# --- App ------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="ComerziaHub"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Mapas / Localização (integração futura) ------------------------------
NEXT_PUBLIC_MAPS_PROVIDER="none"
NEXT_PUBLIC_MAPS_API_KEY=""

# --- Upload de imagens (integração futura) --------------------------------
UPLOAD_PROVIDER="local"
# BLOB_READ_WRITE_TOKEN=""

# --- Pagamentos (integração futura) ---------------------------------------
PAYMENT_PROVIDER="mock"
# PAYMENT_API_KEY=""
